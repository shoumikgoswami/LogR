{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LogR",
  "version": "0.1.0",
  "identifier": "io.logr.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "dashboard",
        "title": "LogR",
        "width": 400,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "LogR — Settings",
        "url": "index.html#settings",
        "width": 480,
        "height": 580,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlistAdditions": {
        "NSScreenCaptureUsageDescription": "LogR captures periodic screenshots to describe your activity. Images are processed locally or via your configured AI provider and are never stored to disk.",
        "NSAppleEventsUsageDescription": "LogR reads the active window title to understand your current context for activity logging."
      }
    }
  }
}
